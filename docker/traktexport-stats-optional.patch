+def _optional_trakt_request(endpoint: str, default: Any) -> Any:
+    """Like ``_trakt_request`` but returns ``default`` if Trakt returns 5xx.
+
+    Some endpoints (notably ``users/<name>/stats``) intermittently return
+    ``500 Internal Server Error`` for accounts with any quirk in their
+    historical data. We don't want the entire export to abort for a
+    single non-critical field.
+    """
+    try:
+        return _trakt_request(endpoint, logger=logger)
+    except TraktInternalException as e:
+        logger.warning(
+            f"Trakt returned 5xx on optional endpoint {endpoint!r}; "
+            f"substituting default. ({e})"
+        )
+        return default
+
